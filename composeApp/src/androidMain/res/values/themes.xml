<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#A9E5BB</item> <!-- Background color -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item> <!-- Icon with padding -->
        <item name="postSplashScreenTheme">@style/AppTheme</item> <!-- Main app theme -->
    </style>

    <!-- Main App Theme (Post Splash) -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
    </style>
</resources>