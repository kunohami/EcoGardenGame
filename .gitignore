# --------------------------------------------------------------------------------
# 📚 Git Ignore for Kotlin Multiplatform / Compose Multiplatform Projects
# --------------------------------------------------------------------------------

# --------------------------------------------------------------------------------
# General Build Artifacts (Gradle, Kotlin, Multiplatform)
# --------------------------------------------------------------------------------
/build/                  # Standard Gradle/Kotlin build output in the root
.gradle/                 # Gradle caches

# Ignore 'build' directories in all submodules (e.g., composeApp/build, shared/build)
**/build/

*.iml                    # IntelliJ Module Files
.DS_Store                # macOS specific files

# Kotlin Multiplatform specific
/.kotlin/                # Ignore Kotlin 2.0 compiler session files

# Specific build cache files that often cause issues in KMP/Compose builds
# These files are typically found inside sub-directories of build/
**/*.tab                 # lookups.tab, id-to-file.tab.*, etc.
**/*.bin                 # last-build.bin, shrunk-classpath-snapshot.bin, etc.
**/report.txt            # debug-report.txt, proguard-rules.txt (if generated)

# --------------------------------------------------------------------------------
# Android Studio / IntelliJ IDE & Local Configuration
# --------------------------------------------------------------------------------
.idea/
!.idea/codeStyles/       # Keep code style settings, but ignore everything else
.idea/workspace.xml
.idea/tasks.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries

# Local configuration - DO NOT commit environment-specific or sensitive data
local.properties
.secrets/

# --------------------------------------------------------------------------------
# Android-specific files & Debug Resources
# --------------------------------------------------------------------------------
# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM and class files
*.dex
*.class

# Generated files
gen/
out/
captures/
.navigation/

# Proguard/R8 mapping files (usually only needed for release crash reporting)
**/mapping/*.txt

# Native build folder (Android Studio 2.2 and later)
.externalNativeBuild/
.cxx/

# Debug Artifacts
# Intermediates folder contains nearly all temporary build files and merged resources
**/build/intermediates/
# Files generated by JaCoCo/Coverage tools
**/*.exec
# Heap dumps used for memory debugging
**/*.hprof
# Test result reports (can get large)
**/build/test-results/
# Temporary resources packaging
**/resources-debug.ap_

# Keystore files (Uncomment if you don't want to commit keystores)
#*.jks
#*.keystore

# --------------------------------------------------------------------------------
# Desktop/Web specific artifacts
# --------------------------------------------------------------------------------
# Kotlin/JVM (Desktop)
/target/

# Kotlin/JS (Web)
/webpack-build/
/node_modules/
/js/
package-lock.json

# --------------------------------------------------------------------------------
# iOS/Native specific artifacts (Xcode)
# --------------------------------------------------------------------------------
# Typically located inside the 'iosApp' directory
# Swift package manager
.swiftpm/

# Xcode build files
xcuserdata/
DerivedData/
*.xcodeproj/project.xcworkspace
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/

# Pods for CocoaPods dependencies
Pods/