# --------------------------------------------------------------------------------
# General Build Artifacts (Gradle, Kotlin, Multiplatform)
# --------------------------------------------------------------------------------
/build/
.gradle/
*.iml
.DS_Store

# Kotlin Multiplatform specific
/.kotlin/ # Ignore Kotlin 2.0 compiler session files

# --------------------------------------------------------------------------------
# Android Studio / IntelliJ IDE
# --------------------------------------------------------------------------------
# Covers JetBrains IDEs: IntelliJ, Android Studio, etc.
# Reference: https://intellij-support.jetbrains.com/hc/en-us/articles/206544839
.idea/
.idea/workspace.xml
.idea/tasks.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries

# Local configuration - DO NOT commit environment-specific or sensitive data
local.properties

# --------------------------------------------------------------------------------
# Android-specific files (often inside the 'androidApp' module's root, or root)
# --------------------------------------------------------------------------------
# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex
# Java/Kotlin class files
*.class

# Generated files
gen/
out/
release/
captures/
.navigation/

# Proguard files
proguard/

# Native build folder (Android Studio 2.2 and later)
.externalNativeBuild/
.cxx/

# Keystore files (Uncomment if you don't want to commit keystores)
#*.jks
#*.keystore

# --------------------------------------------------------------------------------
# iOS/Native specific artifacts (Usually inside the 'shared' or iOS target module)
# --------------------------------------------------------------------------------
# Typically located inside the 'iosApp' directory if you have an iOS target
# Swift package manager
.swiftpm/

# Xcode build files
xcuserdata/
DerivedData/
*.xcodeproj/project.xcworkspace
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
